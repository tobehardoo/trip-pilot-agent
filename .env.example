# Copy this file to .env and fill values locally. Never commit .env.
APP_ENV=local
IMAGE_TAG=local
DEMO_MODE=true
TRAVEL_SERVER_PORT=8080
TRAVEL_SERVER_URL=http://localhost:8080
WEB_PORT=8080
WEB_BIND_ADDRESS=127.0.0.1
TRUSTED_PROXY_CIDR=172.30.250.1/32
APP_NETWORK_SUBNET=172.30.250.0/24
APP_NETWORK_GATEWAY=172.30.250.1
PROMETHEUS_PORT=9090

POSTGRES_DB=trip_pilot
POSTGRES_USER=trip_pilot
POSTGRES_PASSWORD=replace-with-local-password
POSTGRES_PORT=5432

# Optional knowledge-store DSN override. Leave empty to derive from POSTGRES_*.
KNOWLEDGE_DATABASE_URL=
KNOWLEDGE_EMBEDDING_PROVIDER=demo
KNOWLEDGE_EMBEDDING_MODEL=text-embedding-v4
KNOWLEDGE_EMBEDDING_DIMENSIONS=1024
KNOWLEDGE_SOURCE_DIRECTORY=../../knowledge/sources
# Required when KNOWLEDGE_EMBEDDING_PROVIDER=dashscope.
DASHSCOPE_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_TIMEOUT_SECONDS=10

REDIS_PASSWORD=replace-with-local-password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TIMEOUT_SECONDS=2

RABBITMQ_USER=trip_pilot
RABBITMQ_PASSWORD=replace-with-local-password
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
OUTBOX_PUBLISHER_ENABLED=true
OUTBOX_PUBLISHER_DELAY_MS=1000
EVENT_CONSUMER_ENABLED=true

JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes
REFRESH_COOKIE_SECURE=true
# Shared only by the private travel-server -> agent-api connection. Use a distinct random value.
AGENT_INTERNAL_TOKEN=replace-with-a-random-internal-token-at-least-32-bytes

AMAP_WEB_SERVICE_KEY=
AMAP_TIMEOUT_SECONDS=5
POI_CACHE_TTL_SECONDS=86400
# Browser-visible AMap JS API credentials. Never reuse AMAP_WEB_SERVICE_KEY here.
VITE_AMAP_WEB_JS_KEY=
VITE_AMAP_SECURITY_CODE=

DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=qwen
