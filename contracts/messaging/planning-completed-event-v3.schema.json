{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trippilot.local/contracts/planning-completed-event-v3.schema.json",
  "title": "Planning Completed Event v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventType", "schemaVersion", "eventId", "traceId", "taskId",
    "tripId", "runId", "occurredAt", "payload"
  ],
  "properties": {
    "eventType": {"const": "PLANNING_COMPLETED"},
    "schemaVersion": {"const": 3},
    "eventId": {"type": "string", "format": "uuid"},
    "traceId": {"type": "string", "format": "uuid"},
    "taskId": {"type": "string", "format": "uuid"},
    "tripId": {"type": "string", "format": "uuid"},
    "runId": {"type": "string", "format": "uuid"},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {
      "oneOf": [
        {"$ref": "#/$defs/amapPayload"},
        {"$ref": "#/$defs/demoPayload"}
      ]
    }
  },
  "$defs": {
    "amapPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "itinerary"],
      "properties": {
        "provider": {"const": "AMAP"},
        "itinerary": {"$ref": "#/$defs/amapItinerary"}
      }
    },
    "demoPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "itinerary"],
      "properties": {
        "provider": {"const": "DEMO"},
        "itinerary": {"$ref": "#/$defs/demoItinerary"}
      }
    },
    "amapItinerary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "days", "estimatedTotalCost"],
      "properties": {
        "title": {"type": "string", "minLength": 1, "maxLength": 200},
        "days": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/amapDay"}
        },
        "estimatedTotalCost": {"$ref": "#/$defs/money"}
      }
    },
    "demoItinerary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "days", "estimatedTotalCost"],
      "properties": {
        "title": {"type": "string", "minLength": 1, "maxLength": 200},
        "days": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/demoDay"}
        },
        "estimatedTotalCost": {"$ref": "#/$defs/money"}
      }
    },
    "amapDay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "activities", "transitLegs"],
      "properties": {
        "date": {"type": "string", "format": "date"},
        "activities": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/amapActivity"}
        },
        "transitLegs": {"$ref": "#/$defs/transitLegs"}
      }
    },
    "demoDay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "activities", "transitLegs"],
      "properties": {
        "date": {"type": "string", "format": "date"},
        "activities": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/demoActivity"}
        },
        "transitLegs": {"$ref": "#/$defs/transitLegs"}
      }
    },
    "transitLegs": {
      "type": "array",
      "maxItems": 999,
      "items": {"$ref": "#/$defs/transitLeg"}
    },
    "transitLeg": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fromActivityIndex", "toActivityIndex", "mode", "distanceMeters",
        "durationSeconds", "provider", "estimated", "polyline"
      ],
      "properties": {
        "fromActivityIndex": {"type": "integer", "minimum": 0},
        "toActivityIndex": {"type": "integer", "minimum": 1},
        "mode": {"const": "WALKING"},
        "distanceMeters": {"type": "integer", "minimum": 0, "maximum": 40100000},
        "durationSeconds": {"type": "integer", "minimum": 0, "maximum": 31536000},
        "provider": {"enum": ["AMAP", "DEMO"]},
        "estimated": {"type": "boolean"},
        "polyline": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5000,
          "items": {"$ref": "#/$defs/coordinates"}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"provider": {"const": "AMAP"}}},
          "then": {"properties": {"estimated": {"const": false}}}
        },
        {
          "if": {"properties": {"provider": {"const": "DEMO"}}},
          "then": {"properties": {"estimated": {"const": true}}}
        }
      ]
    },
    "amapActivity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title", "startTime", "endTime", "estimatedCost", "source",
        "providerPoiId", "coordinates", "address"
      ],
      "properties": {
        "title": {"type": "string", "minLength": 1, "maxLength": 200},
        "startTime": {"type": "string", "format": "date-time"},
        "endTime": {"type": "string", "format": "date-time"},
        "estimatedCost": {"$ref": "#/$defs/money"},
        "source": {"const": "AMAP"},
        "providerPoiId": {"type": "string", "minLength": 1, "maxLength": 100},
        "coordinates": {"$ref": "#/$defs/coordinates"},
        "address": {"type": "string", "minLength": 1, "maxLength": 300}
      }
    },
    "demoActivity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "startTime", "endTime", "estimatedCost", "source"],
      "properties": {
        "title": {"type": "string", "minLength": 1, "maxLength": 200},
        "startTime": {"type": "string", "format": "date-time"},
        "endTime": {"type": "string", "format": "date-time"},
        "estimatedCost": {"$ref": "#/$defs/money"},
        "source": {"const": "DEMO"}
      }
    },
    "coordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["longitude", "latitude"],
      "properties": {
        "longitude": {"type": "number", "minimum": -180, "maximum": 180},
        "latitude": {"type": "number", "minimum": -90, "maximum": 90}
      }
    },
    "money": {
      "type": "number",
      "minimum": 0,
      "maximum": 9999999999.99,
      "multipleOf": 0.01
    }
  }
}
